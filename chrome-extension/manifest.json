{
  "manifest_version": 3,
  "name": "Curador AVR — Refresh automático",
  "description": "Refresca precios de productos curados de AliExpress en background usando tu sesión real de Chrome. Bypasea anti-bot y mantiene la BD al día sin intervención manual.",
  "version": "1.0.0",
  "permissions": ["tabs", "scripting", "alarms", "storage", "windows"],
  "host_permissions": [
    "https://*.aliexpress.com/*",
    "https://vlhoshlnkmsojeqejzwo.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Curador AVR",
    "default_icon": {
      "16": "icons/icon-128.png",
      "48": "icons/icon-128.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-128.png",
    "48": "icons/icon-128.png",
    "128": "icons/icon-128.png"
  }
}
